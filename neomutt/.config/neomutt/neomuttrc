source ~/.config/neomutt/secrets

# Identity
set realname = "Xiyuan Guo"
set from = "tommyguo039@gmail.com"
set use_from = yes
set envelope_from = yes

# IMAP / Mailboxes
set folder = "imaps://imap.gmail.com:993"
set imap_user = "tommyguo039@gmail.com"
set spoolfile = "+INBOX"
set postponed = "+[Gmail]/Drafts"
set record = "+[Gmail]/Sent Mail"
set trash = "+[Gmail]/Trash"
mailboxes "+INBOX" "+[Gmail]/Sent Mail" "+[Gmail]/Drafts" "+[Gmail]/Trash"

# SMTP
set smtp_authenticators = "login"
set smtp_url = "smtps://tommyguo039%40gmail.com@smtp.gmail.com:465"

# Performance & Cache (Required for speed)
set header_cache = "~/.cache/neomutt/headers"
set message_cachedir = "~/.cache/neomutt/bodies"
set imap_keepalive = 300
set mail_check = 60

# Editor & Composition
set editor = "nvim"
set text_flowed = no
set send_charset = "us-ascii:utf-8"
set fast_reply = yes
set include = yes

# Pager
set pipe_decode = yes
bind pager j next-line
bind pager k previous-line
bind pager \Cd half-down
bind pager \Cu half-up

# UI & Behavior
set help = no
set markers = no
set mark_old = no
set sort = threads
set sort_aux = reverse-last-date-received
set menu_scroll = yes

# Headers
ignore *
unignore from: to: cc: date: subject:
hdr_order from: to: cc: date: subject:

# Monochrome Palette
color normal default default
color indicator reverse default default
color tree default default
color status reverse default default
color error red default
color quoted default default
